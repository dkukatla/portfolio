---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Page Not Found">
  <main class="not-found-container">
    <div class="glass glass-hover spotlight tilt-card error-card">
      <h1 class="error-code gradient-text">404</h1>
      <h2 class="error-title scramble-text" data-text="System Exception">System Exception</h2>
      <p class="error-message">
        The requested resource could not be found in this server's index.
        The page may have been moved, deleted, or perhaps never existed.
      </p>
      <a href="/" class="btn-primary home-btn">
        <span>Return to Base</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="position:relative;z-index:1">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
      </a>
    </div>
  </main>
</Layout>

<style>
  .not-found-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    position: relative;
    z-index: 10;
  }

  .error-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 3rem 2rem;
    max-width: 600px;
    width: 100%;
  }

  .error-code {
    font-size: clamp(6rem, 20vw, 10rem);
    font-weight: 800;
    line-height: 1;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 30px rgba(99, 102, 241, 0.4));
  }

  .error-title {
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    font-family: 'Space Grotesk', sans-serif;
  }

  .error-message {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  .home-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.75rem;
    font-size: 1.05rem;
    text-decoration: none;
  }
</style>
