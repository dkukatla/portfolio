---

<section id="contact" class="section-container">
  <h2 class="section-title reveal">
    Get In <span class="gradient-text">Touch</span>
  </h2>
  <p class="section-subtitle reveal">
    Hiring for a software engineer who can own architecture and deliver fast? Let's talk.
  </p>

  <div class="contact-grid">
    <div class="contact-info reveal-left">
      <h3 class="contact-heading">Bring me your toughest engineering problems.</h3>
      <p class="contact-text">
        I help teams ship scalable products, modernize systems, and implement AI features that create
        measurable value. If you are hiring for someone who can design clean architecture, code at speed,
        and communicate clearly with stakeholders, I would love to connect.
      </p>

      <div class="contact-details">
        <a href="https://mail.google.com/mail/?view=cm&fs=1&to=dhanushnaidu2000@gmail.com" target="_blank" class="contact-item glass glass-hover">
          <div class="contact-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2" />
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
            </svg>
          </div>
          <div>
            <span class="contact-label">Email</span>
            <span class="contact-value">dhanushnaidu2000@gmail.com</span>
          </div>
        </a>
        <a href="tel:+16232749710" class="contact-item glass glass-hover">
          <div class="contact-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
          </div>
          <div>
            <span class="contact-label">Phone</span>
            <span class="contact-value">(623) 274-9710</span>
          </div>
        </a>
        <a href="https://www.linkedin.com/in/kdhanush0211" target="_blank" class="contact-item glass glass-hover">
          <div class="contact-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </div>
          <div>
            <span class="contact-label">LinkedIn</span>
            <span class="contact-value">linkedin.com/in/kdhanush0211</span>
          </div>
        </a>
      </div>
    </div>

    <form class="contact-form glass reveal-right" id="contact-form">
      <div class="form-group">
        <label for="name" class="form-label">Full Name*</label>
        <input type="text" id="name" name="name" class="form-input" placeholder="First Name Last Name" required />
      </div>
      <div class="form-group">
        <label for="email" class="form-label">Email Address*</label>
        <input type="email" id="email" name="email" class="form-input" placeholder="abc@xyz.com" required />
      </div>
      <div class="form-group">
        <label for="message" class="form-label">Message</label>
        <textarea id="message" name="message" class="form-input form-textarea" rows="5"
          placeholder="Tell me about your project..." required></textarea>
      </div>
      <button type="submit" class="btn-primary form-submit">
        <span>Send Message</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          style="position:relative;z-index:1">
          <path d="m22 2-7 20-4-9-9-4z" />
          <path d="M22 2 11 13" />
        </svg>
      </button>
    </form>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* ── Info Side ── */
  .contact-heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 1rem;
  }

  .contact-text {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .contact-item:hover {
    transform: translateX(6px);
  }

  .contact-icon-wrapper {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg,
        rgba(99, 102, 241, 0.14) 0%,
        rgba(99, 102, 241, 0.06) 100%);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(99, 102, 241, 0.15);
    color: var(--accent-1);
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(99, 102, 241, 0.08);
  }

  .contact-label {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-value {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  /* ── Form ── */
  .contact-form {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .form-input {
    padding: 0.85rem 1rem;
    background: linear-gradient(135deg,
        rgba(255, 255, 255, 0.05) 0%,
        rgba(255, 255, 255, 0.02) 100%);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    transition: all var(--transition-fast);
    outline: none;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .form-input::placeholder {
    color: var(--text-muted);
  }

  .form-input:focus {
    border-color: rgba(99, 102, 241, 0.5);
    box-shadow:
      0 0 0 3px rgba(99, 102, 241, 0.12),
      0 0 20px rgba(99, 102, 241, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    background: linear-gradient(135deg,
        rgba(255, 255, 255, 0.07) 0%,
        rgba(255, 255, 255, 0.03) 100%);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
    padding: 1rem;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>