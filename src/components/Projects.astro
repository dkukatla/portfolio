---
const projects = [
  {
    title: 'AI Knowledge Assistant',
    description: 'An AI-powered knowledge assistant serving 10K+ users/day with Spring Boot, Pinecone vector store, OpenAI embeddings, and a Next.js chat UI — reducing average support resolution time from 18 to 12 minutes.',
    image: '/images/project-2.webp',
    tags: ['Spring Boot', 'OpenAI', 'Pinecone', 'Next.js', 'LangChain'],
    github: 'https://github.com',
    live: 'https://example.com',
  },
  {
    title: 'Document Intelligence Platform',
    description: 'End-to-end RAG platform with agentic query resolution using LangGraph multi-step reasoning and LangChain tool-calling, a React streaming UI with cited answers, and retrieval latency under 200ms.',
    image: '/images/project-1.webp',
    tags: ['Java', 'FastAPI', 'LangGraph', 'React', 'Docker', 'AWS'],
    github: 'https://github.com',
    live: 'https://example.com',
  },
  {
    title: 'Enterprise Workflow Platform',
    description: 'Microservices-based onboarding and approval system for 5 business teams. Includes per-role dashboards, multi-step approval flows, real-time WebSocket notifications, and GraphQL APIs.',
    image: '/images/project-3.webp',
    tags: ['Spring Boot', 'Next.js', 'GraphQL', 'WebSockets', 'PostgreSQL'],
    github: 'https://github.com',
    live: 'https://example.com',
  },
  {
    title: 'Request Management System',
    description: 'Internal platform replacing a manual email-based process. Features MySQL-backed REST/GraphQL APIs, Elasticsearch full-text search across 50K+ documents with sub-second query times.',
    image: '/images/project-4.webp',
    tags: ['Spring Boot', 'MySQL', 'Elasticsearch', 'GraphQL', 'REST'],
    github: 'https://github.com',
    live: 'https://example.com',
  },
  {
    title: 'Digieye — Accessibility Assistant',
    description: 'Android application delivering real-time assistance for 100+ visually impaired users through speech-based interaction. Features OCR, object detection, and safety workflows using Google ML Kit, TensorFlow Lite, and Twilio, with live location sharing and emergency alerts via Google Maps API.',
    image: '/images/project-5.webp',
    tags: ['Java', 'Firebase', 'TensorFlow Lite', 'Google ML Kit', 'Twilio'],
    github: 'https://github.com',
    live: 'https://example.com',
  },
  {
    title: 'Satellite Imagery Analysis',
    description: 'Machine learning platform analyzing Sentinel-2 satellite data for land cover classification, achieving 87% accuracy through advanced preprocessing and algorithm optimization using TensorFlow and scikit-learn.',
    image: '/images/project-6.webp',
    tags: ['Python', 'TensorFlow', 'Scikit-Learn', 'Algorithms', 'ML'],
    github: 'https://github.com',
    live: 'https://example.com',
  },
  {
    title: 'Smart Price Finder',
    description: 'Full-stack price comparison platform that searches multiple retailers for a given product, aggregates listings with prices, and highlights the best deal. Built with a responsive frontend and a backend that scrapes and normalizes pricing data in real time.',
    image: '/images/project-7.webp',
    tags: ['Full Stack', 'Web Scraping', 'REST API', 'JavaScript', 'Node.js'],
    github: 'https://github.com',
    live: 'https://example.com',
  },
];
---

<section id="projects" class="section-container">
  <h2 class="section-title reveal">
    Featured <span class="gradient-text">Projects</span>
  </h2>
  <p class="section-subtitle reveal">
    Click a card to see details. Click again to flip back.
  </p>

  <div class="projects-grid stagger-children">
    {projects.map((project) => (
      <div class="flip-card reveal" tabindex="0" aria-expanded="false">
        <div class="flip-card-inner">
          <!-- FRONT -->
          <div class="flip-face flip-front spotlight">
            <div class="front-img-wrap">
              <img
                src={project.image}
                alt={project.title}
                class="front-img"
                width="400"
                height="225"
                loading="lazy"
              />
              <div class="front-gradient"></div>
            </div>
            <div class="front-bar">
              <h3 class="front-title">{project.title}</h3>
              <span class="flip-hint">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 1l4 4-4 4"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><path d="M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
              </span>
            </div>
          </div>

          <!-- BACK -->
          <div class="flip-face flip-back spotlight">
            <h3 class="back-title">{project.title}</h3>
            <p class="back-desc">{project.description}</p>
            <div class="back-tags">
              {project.tags.map(tag => (
                <span class="ptag">{tag}</span>
              ))}
            </div>
            <div class="back-links">
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="back-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                Source
              </a>
              <a href={project.live} target="_blank" rel="noopener noreferrer" class="back-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Demo
              </a>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style is:global>
  /* ── Grid ── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── Flip Card Container ── */
  .flip-card {
    perspective: 1200px;
    cursor: pointer;
    height: 320px;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.65s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }

  .flip-card.flipped .flip-card-inner {
    transform: rotateY(180deg);
  }

  /* ── Both Faces ── */
  .flip-face {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: var(--radius-lg);
    overflow: hidden;
    /* Glass styles inline — avoids .glass class conflicts */
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.06) 0%,
      rgba(255, 255, 255, 0.02) 50%,
      rgba(255, 255, 255, 0.04) 100%
    );
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  /* ── Front Face ── */
  .flip-front {
    display: flex;
    flex-direction: column;
    z-index: 2;
  }

  .front-img-wrap {
    position: relative;
    flex: 1;
    overflow: hidden;
  }

  .front-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .flip-card:hover .front-img {
    transform: scale(1.06);
  }

  .front-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 10, 15, 0.65) 0%,
      transparent 50%
    );
    pointer-events: none;
  }

  .front-bar {
    padding: 0.9rem 1.2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .front-title {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-primary);
  }

  .flip-hint {
    color: var(--text-muted);
    opacity: 0;
    transition: opacity var(--transition-fast);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .flip-card:hover .flip-hint {
    opacity: 1;
  }

  /* Front hover glow */
  .flip-card:hover .flip-front {
    border-color: rgba(255, 255, 255, 0.18);
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.3),
      0 0 60px rgba(99, 102, 241, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  /* ── Back Face ── */
  .flip-back {
    transform: rotateY(180deg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1.5rem;
    gap: 0.85rem;
  }

  .back-title {
    font-size: 1rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .back-desc {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .back-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .ptag {
    padding: 0.18rem 0.55rem;
    font-size: 0.66rem;
    font-weight: 500;
    color: var(--accent-1);
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: var(--radius-full);
  }

  .back-links {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.25rem;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.9rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-primary);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.08) 0%,
      rgba(255, 255, 255, 0.03) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-full);
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .back-btn:hover {
    background: rgba(99, 102, 241, 0.15);
    border-color: rgba(99, 102, 241, 0.35);
    color: var(--accent-1);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.12);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    .flip-card {
      height: 300px;
    }
  }
</style>

<script>
  const projectCards = Array.from(document.querySelectorAll('.flip-card'));

  projectCards.forEach((card) => {
    card.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) return;

      const shouldFlip = !card.classList.contains('flipped');
      projectCards.forEach((otherCard) => {
        otherCard.classList.remove('flipped');
        otherCard.setAttribute('aria-expanded', 'false');
      });

      if (shouldFlip) {
        card.classList.add('flipped');
      }
      card.setAttribute('aria-expanded', String(shouldFlip));
    });
    card.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault();

        const shouldFlip = !card.classList.contains('flipped');
        projectCards.forEach((otherCard) => {
          otherCard.classList.remove('flipped');
          otherCard.setAttribute('aria-expanded', 'false');
        });

        if (shouldFlip) {
          card.classList.add('flipped');
        }
        card.setAttribute('aria-expanded', String(shouldFlip));
      }
    });
  });
</script>
