---
const skillCategories = [
  {
    title: "Languages",
    icon: "⌨️",
    skills: ["Java", "Python", "SQL", "TypeScript", "JavaScript"],
  },
  {
    title: "Backend & APIs",
    icon: "⚙️",
    skills: [
      "Spring Boot",
      "FastAPI",
      "Node.js",
      "REST APIs",
      "GraphQL",
      "gRPC",
      "WebSockets",
      "Microservices",
    ],
  },
  {
    title: "Frontend",
    icon: "🧩",
    skills: ["React", "Next.js", "Angular"],
  },
  {
    title: "Architecture & Systems",
    icon: "🏗️",
    skills: [
      "Distributed Systems",
      "System Design",
      "Event-Driven Architecture",
      "API Design",
      "Asynchronous Processing",
    ],
  },
  {
    title: "Databases, Search & Messaging",
    icon: "🗄️",
    skills: [
      "PostgreSQL",
      "MySQL",
      "MongoDB",
      "Elasticsearch",
      "Redis",
      "Kafka",
      "Pinecone",
    ],
  },
  {
    title: "Cloud & DevOps",
    icon: "☁️",
    skills: [
      "AWS (EC2, Lambda, CloudWatch)",
      "Docker",
      "Kubernetes",
      "Terraform",
      "GitHub Actions",
      "Azure",
      "GCP",
      "Linux",
    ],
  },
  {
    title: "Observability & Reliability",
    icon: "📈",
    skills: [
      "Monitoring",
      "Logging",
      "Alerting",
      "Prometheus",
      "Grafana",
      "Datadog",
    ],
  },
  {
    title: "AI/ML Tech & Tools",
    icon: "🤖",
    skills: [
      "OpenAI GPT",
      "LLMs",
      "LLM Agents",
      "LangChain",
      "LangGraph",
      "RAG Pipelines",
      "Vector Search & Embedding",
      "Prompt Engineering",
      "Retrieval Optimization",
      "Cursor IDE",
      "Gravity Write",
    ],
  },
];

const defaultSkillIcon =
  '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="2.2" fill="currentColor"/></svg>';

function getSkillIcon(skill: string) {
  const exactIcons: Record<string, string> = {
    Java: '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8.8 18.5c1.2.6 5.5.7 6.7-.1" stroke="#5382A1" stroke-width="1.2" fill="none"/><path d="M12.9 6.2c1.2 1.3-.3 2.5-.3 2.5s2.9-1.5 1.5-3.4C12.8 3.6 12 2.8 17.2 0c0 0-8.2 2-4.3 6.2z" fill="#E76F00"/></svg>',
    Python:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 0C6 0 6.3 2.7 6.3 2.7V6H12v1H3.9S0 6.7 0 12.1s3.4 5.9 3.4 5.9h2V15s-.1-3.4 3.3-3.4h5.8S18 11.6 18 8.5V3.2S18.3 0 12 0z" fill="#366C9C"/><path d="M12 24c6 0 5.7-2.7 5.7-2.7V18H12v-1h8.1s3.9.3 3.9-5.1S20.6 6 20.6 6h-2v2.9s.1 3.4-3.3 3.4H9.5S6.2 12.2 6.2 15.4v5.2S5.9 24 12 24z" fill="#FFC331"/></svg>',
    TypeScript:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect width="24" height="24" rx="3" fill="#3178C6"/><path d="M6 8h12v2h-5v8h-2v-8H6z" fill="#fff"/></svg>',
    JavaScript:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect width="24" height="24" fill="#F7DF1E"/><path d="M7 18c.3.6.8 1 1.6 1 .8 0 1.3-.3 1.3-1.4V9.8h2.2v7.9c0 2.4-1.4 3.4-3.4 3.4-1.9 0-2.9-.9-3.5-2z" fill="#111"/></svg>',
    React:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="2.1" fill="#61DAFB"/><g stroke="#61DAFB" stroke-width="1" fill="none"><ellipse cx="12" cy="12" rx="10" ry="4"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(120 12 12)"/></g></svg>',
    "Next.js":
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="11" fill="#fff"/><path d="M9 7v10h2V10l4 7h2V7h-2v7l-4-7z" fill="#000"/></svg>',
    Angular:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l8.5 3-1.3 11.3L12 20l-7.2-3.7L3.5 5 12 2z" fill="#DD0031"/><path d="M12 6.5l-3 7h1.4l.6-1.6h2.1l.6 1.6H15l-3-7z" fill="#fff"/></svg>',
    "Spring Boot":
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22 8.6c-2 2.9-5.3 4.8-9.2 4.8H3.2c.1 4.2 3.6 7.6 7.8 7.6 5 0 8.6-2.3 10.3-7.1-.2-.7-.1-3.1.7-5.3z" fill="#6DB33F"/></svg>',
    FastAPI:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l-6 10h4v10l8-14h-4V2z" fill="#009688"/></svg>',
    "Node.js":
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 1.8l8.2 4.7v11L12 22.2l-8.2-4.7v-11L12 1.8z" fill="#689F63"/><path d="M9.4 8.1h1.3v6.2H9.4zm2.5 0h1.3l2 3.4V8.1h1.2v6.2h-1.2l-2.1-3.5v3.5h-1.2z" fill="#fff"/></svg>',
    GraphQL:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l8 4.6v10.8L12 22l-8-4.6V6.6L12 2z" stroke="#E535AB" stroke-width="1.2" fill="none"/><circle cx="12" cy="2" r="2" fill="#E535AB"/></svg>',
    PostgreSQL:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><ellipse cx="12" cy="6" rx="7.5" ry="3.2" fill="none" stroke="#60a5fa" stroke-width="1.4"/><path d="M4.5 6v12c0 1.8 3.4 3.2 7.5 3.2s7.5-1.4 7.5-3.2V6" fill="none" stroke="#60a5fa" stroke-width="1.4"/></svg>',
    MySQL:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><ellipse cx="12" cy="6" rx="7.5" ry="3.2" fill="none" stroke="#60a5fa" stroke-width="1.4"/><path d="M4.5 6v12c0 1.8 3.4 3.2 7.5 3.2s7.5-1.4 7.5-3.2V6" fill="none" stroke="#60a5fa" stroke-width="1.4"/></svg>',
    MongoDB:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2c2 3 4 6 4 10a4 4 0 1 1-8 0c0-4 2-7 4-10z" fill="#00ED64"/></svg>',
    Elasticsearch:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="10" cy="10" r="6.5" fill="none" stroke="#f59e0b" stroke-width="1.8"/><path d="M15 15l6 6" stroke="#f59e0b" stroke-width="1.8" stroke-linecap="round"/></svg>',
    Redis:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 8l9-4 9 4-9 4-9-4zm0 5l9 4 9-4" fill="#D82C20"/></svg>',
    Kafka:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="6" r="2" fill="#fff"/><circle cx="12" cy="18" r="2" fill="#fff"/><path d="M12 8v8" stroke="#fff" stroke-width="1.6"/><circle cx="6" cy="12" r="2" fill="#fff"/><circle cx="18" cy="12" r="2" fill="#fff"/></svg>',
    Kubernetes:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9.5" fill="none" stroke="#326CE5" stroke-width="1.6"/><path d="M12 6l4 2.3v4.6L12 15l-4-2.1V8.3L12 6z" fill="#326CE5"/></svg>',
    Terraform:
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M2 2v7l6 3.5V5.5L2 2zm7 3.5v7l6-3.5V2L9 5.5zm7-3.5v7l6 3.5V5.5L16 2z" fill="#5C4EE5"/></svg>',
    "GitHub Actions":
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2a10 10 0 0 0-3 19.5v-3.4c-2.7.6-3.3-1.2-3.3-1.2-.5-1-.9-1.4-.9-1.4-.8-.5 0-.5 0-.5.9.1 1.4.9 1.4.9.8 1.4 2.1 1 2.7.8.1-.6.3-1 .6-1.2-2.2-.3-4.6-1.1-4.6-4.8 0-1 .4-1.8 1-2.5-.1-.2-.4-1.2.1-2.5 0 0 .8-.3 2.6 1 .8-.2 1.6-.3 2.4-.3s1.6.1 2.4.3c1.8-1.3 2.6-1 2.6-1 .5 1.3.2 2.3.1 2.5.6.7 1 1.5 1 2.5 0 3.7-2.4 4.5-4.7 4.8.4.3.7.9.7 1.8v2.7A10 10 0 0 0 12 2z" fill="#fff"/></svg>',
    "OpenAI GPT":
      '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l7 4v8l-7 4-7-4V6l7-4z" fill="none" stroke="#10A37F" stroke-width="1.6"/><path d="M12 7l3 1.7v3.4L12 13.8l-3-1.7V8.7L12 7z" fill="#10A37F"/></svg>',
  };

  if (exactIcons[skill]) return exactIcons[skill];
  if (skill.startsWith("AWS"))
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4 16c4 2.8 11 3 16 .2" stroke="#FF9900" stroke-width="1.7" fill="none"/><path d="M18 8h2l-1.2 2.6" stroke="#FF9900" stroke-width="1.5" fill="none"/></svg>';
  if (skill === "REST APIs")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="5" width="18" height="3" rx="1.5" fill="#38bdf8"/><rect x="3" y="10.5" width="18" height="3" rx="1.5" fill="#38bdf8"/><rect x="3" y="16" width="11" height="3" rx="1.5" fill="#38bdf8"/></svg>';
  if (["gRPC", "WebSockets", "API Design"].includes(skill))
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4 7h16M4 12h16M4 17h10" stroke="#7dd3fc" stroke-width="1.8" stroke-linecap="round"/></svg>';
  if (
    [
      "Distributed Systems",
      "System Design",
      "Event-Driven Architecture",
      "Asynchronous Processing",
      "Microservices",
    ].includes(skill)
  )
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="7" height="6" rx="1.2" stroke="#a78bfa" fill="none"/><rect x="14" y="4" width="7" height="6" rx="1.2" stroke="#a78bfa" fill="none"/><rect x="8.5" y="14" width="7" height="6" rx="1.2" stroke="#a78bfa" fill="none"/><path d="M10 7h4M8.5 14l2-4m5 0l-2 4" stroke="#a78bfa" stroke-width="1.2"/></svg>';
  if (skill === "Docker")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="10" width="3" height="3" fill="#2496ED"/><rect x="7" y="10" width="3" height="3" fill="#2496ED"/><rect x="11" y="10" width="3" height="3" fill="#2496ED"/><rect x="7" y="6" width="3" height="3" fill="#2496ED"/><rect x="11" y="6" width="3" height="3" fill="#2496ED"/><path d="M3 14h14a3.5 3.5 0 0 1-3.2 3H8a5 5 0 0 1-5-3z" fill="#2496ED"/></svg>';
  if (skill === "Azure")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4 19L11.4 4h4.2L8.2 19H4z" fill="#0078D4"/><path d="M13.2 4H20l-7.3 15h-4.2L13.2 4z" fill="#0078D4" opacity=".8"/></svg>';
  if (skill === "GCP")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8.8 17.5a4.5 4.5 0 1 1 .7-8.9 5 5 0 0 1 9 2.3A3.4 3.4 0 1 1 18 17.5H8.8z" fill="none" stroke="#4285F4" stroke-width="1.6"/><path d="M8.8 17.5h4.4" stroke="#34A853" stroke-width="1.6"/><path d="M13.2 17.5H18" stroke="#FBBC05" stroke-width="1.6"/></svg>';
  if (skill === "Linux")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><ellipse cx="12" cy="8.5" rx="3.3" ry="3.6" fill="#111"/><ellipse cx="12" cy="14.5" rx="4.2" ry="4.6" fill="#111"/><ellipse cx="10.2" cy="8.4" rx="0.35" ry="0.45" fill="#fff"/><ellipse cx="13.8" cy="8.4" rx="0.35" ry="0.45" fill="#fff"/><path d="M10.8 9.8h2.4" stroke="#fbbf24" stroke-width="0.8" stroke-linecap="round"/></svg>';
  if (skill === "Kubernetes")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9" fill="none" stroke="#326CE5" stroke-width="1.6"/><path d="M12 6.8l3.8 2.2v4.3L12 15.5 8.2 13.3V9z" fill="#326CE5"/><circle cx="12" cy="12" r="1.5" fill="#fff"/></svg>';
  if (skill === "Monitoring")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 17h18M6 14l3-3 2 2 4-5 3 4" stroke="#f59e0b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  if (skill === "Logging")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M5 6h14M5 11h14M5 16h10" stroke="#f59e0b" stroke-width="1.8" stroke-linecap="round"/></svg>';
  if (skill === "Alerting")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 3l9 16H3L12 3z" fill="none" stroke="#f59e0b" stroke-width="1.8"/><circle cx="12" cy="15.5" r="1.2" fill="#f59e0b"/><path d="M12 9v4" stroke="#f59e0b" stroke-width="1.6" stroke-linecap="round"/></svg>';
  if (skill === "Prometheus")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="8.5" fill="none" stroke="#e6522c" stroke-width="1.8"/><path d="M12 7v5l3 2" stroke="#e6522c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  if (skill === "Grafana")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="10" cy="14" r="4" fill="#f97316"/><circle cx="15.5" cy="8.5" r="2.5" fill="#f97316"/><path d="M4 18c2.5-1.6 5-1.6 7.5 0" stroke="#f97316" stroke-width="1.6" fill="none" stroke-linecap="round"/></svg>';
  if (skill === "Datadog")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="4" width="16" height="16" rx="4" fill="#6b46c1"/><path d="M8 14V9M11 14V7M14 14v-3M17 14V8" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/></svg>';
  if (skill === "LLMs")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="4" width="16" height="16" rx="3" fill="none" stroke="#34d399" stroke-width="1.5"/><path d="M8 12h8M12 8v8" stroke="#34d399" stroke-width="1.5"/></svg>';
  if (skill === "LLM Agents")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="12" r="2" fill="#34d399"/><circle cx="16" cy="8" r="2" fill="#34d399"/><circle cx="16" cy="16" r="2" fill="#34d399"/><path d="M9.8 11l4.4-2M9.8 13l4.4 2" stroke="#34d399" stroke-width="1.4"/></svg>';
  if (skill === "LangChain")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 7h8v4H8zM8 13h8v4H8z" fill="none" stroke="#34d399" stroke-width="1.5"/><path d="M10 11v2m4-2v2" stroke="#34d399" stroke-width="1.5"/></svg>';
  if (skill === "LangGraph")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="6" cy="12" r="2" fill="#34d399"/><circle cx="12" cy="6" r="2" fill="#34d399"/><circle cx="18" cy="12" r="2" fill="#34d399"/><circle cx="12" cy="18" r="2" fill="#34d399"/><path d="M7.5 10.8l3-3.6m3 0l3 3.6m-3 2.4l3 3.6m-6 0l-3-3.6" stroke="#34d399" stroke-width="1.2"/></svg>';
  if (skill === "RAG Pipelines")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4 6h16M4 12h10M4 18h6" stroke="#34d399" stroke-width="1.7" stroke-linecap="round"/><path d="M16 10l4 2-4 2z" fill="#34d399"/></svg>';
  if (skill === "Vector Search & Embedding")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="7" cy="7" r="2" fill="#34d399"/><circle cx="17" cy="7" r="2" fill="#34d399"/><circle cx="7" cy="17" r="2" fill="#34d399"/><circle cx="17" cy="17" r="2" fill="#34d399"/><path d="M9 7h6M7 9v6M17 9v6M9 17h6" stroke="#34d399" stroke-width="1.2"/></svg>';
  if (skill === "Prompt Engineering")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M5 4h14v12H8l-3 3V4z" fill="none" stroke="#34d399" stroke-width="1.5"/><path d="M8 8h8M8 11h6" stroke="#34d399" stroke-width="1.5" stroke-linecap="round"/></svg>';
  if (skill === "Retrieval Optimization")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="10" cy="10" r="5.5" fill="none" stroke="#34d399" stroke-width="1.6"/><path d="M14 14l6 6M8 10h4" stroke="#34d399" stroke-width="1.6" stroke-linecap="round"/></svg>';
  if (skill === "Cursor IDE")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4 4l14 8-14 8 3-8z" fill="#34d399"/></svg>';
  if (skill === "Gravity Write")
    return '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M6 18h12M8 6h8l-1.5 8h-5z" fill="none" stroke="#34d399" stroke-width="1.5"/><circle cx="12" cy="10" r="1" fill="#34d399"/></svg>';
  return defaultSkillIcon;
}
---

<section id="skills" class="skills-section">
  <div class="section-container">
    <h2 class="section-title reveal">
      Technical <span class="gradient-text">Skills</span>
    </h2>
    <p class="section-subtitle reveal">
      The technologies and tools I use to build production systems.
    </p>

    <div class="skills-grid stagger-children">
      {
        skillCategories.map((category) => (
          <div class="skill-category glass reveal spotlight tilt-card">
            <div class="category-header">
              <span class="category-icon">{category.icon}</span>
              <h3 class="category-title">{category.title}</h3>
            </div>
            <div class="skill-list">
              {category.skills.map((skill) => (
                <div class="skill-item">
                  <span class="skill-icon" set:html={getSkillIcon(skill)} />
                  <span class="skill-name">{skill}</span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="certs-section reveal">
      <div class="certs-divider"></div>
      <h3 class="certs-heading">Certifications</h3>
      <div class="certs-grid">
        <!-- AWS Solutions Architect -->
        <div class="cert-card glass glass-hover aws spotlight tilt-card">
          <div class="cert-logo-wrapper aws-bg">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 64 64"
              class="cert-logo"
