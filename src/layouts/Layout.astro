---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Dhanush Kukatla — Software Engineer", 
  description = "Software Engineer with 2+ years shipping production systems. Built and operated a 10K-user/day AI knowledge assistant. Experienced with Spring Boot, Next.js, AWS, and AI/ML technologies. M.S. Computer Science, Arizona State University."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Dhanush Kukatla" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      import '../scripts/main.js';
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
